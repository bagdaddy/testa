{
  "name": "@testa-platform/edge",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Cloudflare Worker — serves pixel from KV, accepts /track, sets first-party cookies",
  "main": "src/index.ts",
  "scripts": {
    "build": "wrangler deploy --dry-run --outdir dist",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo .wrangler coverage"
  },
  "dependencies": {
    "hono": "4.6.10",
    "ua-parser-js": "1.0.39"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.5.30",
    "@cloudflare/workers-types": "4.20241112.0",
    "@testa-platform/shared-types": "workspace:*",
    "@types/ua-parser-js": "0.7.39",
    "typescript": "5.6.3",
    "vitest": "2.1.5",
    "wrangler": "3.86.1"
  }
}
