# Collector environment template. Copy to .env for local dev; .env is gitignored.

ENVIRONMENT=development
PORT=8000

# ClickHouse
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=default

# Redis (events stream)
REDIS_URL=redis://localhost:6379
REDIS_STREAM_KEY=events
REDIS_CONSUMER_GROUP=collector-writers

# HMAC shared with edge worker. MUST be at least 16 chars.
INGEST_SHARED_SECRET=dev-secret-change-me-please-1234
INGEST_REPLAY_WINDOW=300

# Service-to-service token shared with crobot for the read API.
SERVICE_TOKEN=dev-service-token-change-me-1234

# FX rates source
FX_API_URL=https://api.frankfurter.app

# Consumer tuning
CONSUMER_BATCH_SIZE=1000
CONSUMER_FLUSH_INTERVAL_MS=5000
