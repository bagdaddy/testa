{
  "name": "@testa-platform/pixel",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Testa client SDK — loader stub + runtime (experiment engine + tracking)",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "check:size": "node esbuild.config.mjs && node scripts/check-bundle-size.mjs",
    "clean": "rm -rf dist .turbo coverage playwright-report test-results"
  },
  "devDependencies": {
    "@playwright/test": "1.48.2",
    "@testa-platform/shared-types": "workspace:*",
    "@types/node": "22.9.0",
    "@vitest/coverage-v8": "2.1.5",
    "esbuild": "0.24.0",
    "happy-dom": "15.11.4",
    "typescript": "5.6.3",
    "vitest": "2.1.5"
  }
}
