  CUST[Customer site<br/>SmartCode + Pixel]
  EDGE[Per-customer<br/>Edge Worker<br/>CF]
  COL[Collector<br/>Bun + Hono]
  REDIS[(Redis<br/>stream + dedup)]
  CN[Consumer<br/>Bun process]
  CH[(ClickHouse<br/>events + 5 MVs)]
  CROBOT[Crobot<br/>Laravel + MySQL<br/>testa-admin]
  VUE[Vue dashboards]

  CUST --> EDGE
  EDGE --> COL
  COL --> REDIS
  REDIS --> CN
  CN --> CH
  CROBOT -. publish KV .-> EDGE
  CROBOT -. provision .-> EDGE
  VUE --> CROBOT
  CROBOT -. proxy .-> COL
  COL -. read .-> CH
  CUST -. legacy /api/leads .-> CROBOT

  class CUST c1
  class EDGE c2
  class COL,REDIS,CN,CH c3
  class CROBOT,VUE c4
